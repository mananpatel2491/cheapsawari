# cheapsawari environment — copy to .env and fill in. .env is gitignored (never commit secrets).

# Which fare data source to use: "mock" (default, zero-quota, used by tests) or "amadeus".
FARE_PROVIDER=mock

# Amadeus Self-Service credentials (required only when FARE_PROVIDER=amadeus).
# Free test tier ≈ 2,000 requests/month (~66/day) — this quota shapes the polling design.
# Get keys at https://developers.amadeus.com (Self-Service).
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Test env by default; switch to https://api.amadeus.com for production.
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CURRENCY=USD

# --- Persistence ---
# Store backend: "sqlite" (default, local) or "firestore" (cloud; used in prod).
WATCH_STORE=sqlite
# SQLite file path (when WATCH_STORE=sqlite). Gitignored.
SQLITE_PATH=cheapsawari.db
# GCP project for Firestore (when WATCH_STORE=firestore). Cloud Run infers this from
# the metadata server; set locally if ADC doesn't resolve it. e.g. cheapsawari
GOOGLE_CLOUD_PROJECT=

# --- Scheduled polling (Slice 3a) ---
# Max active watches queried per poll run — keeps the fleet under the provider quota.
POLL_MAX_PER_RUN=60
# Optional shared secret. If set, POST /api/v1/poll requires header X-Poll-Token: <value>.
# Leave blank for local/dev (endpoint open); set it in cloud so the public URL is protected.
POLL_TOKEN=

# --- Signal detection + alerts (Slice 4) ---
# Where to deliver "bucket reopened" alerts: "log" (default; zero-cost, prod-safe,
# captured in Cloud Run logs) or "webhook".
ALERT_CHANNEL=log
# Incoming-webhook URL for ALERT_CHANNEL=webhook (Slack/Discord/Mattermost/generic).
# If ALERT_CHANNEL=webhook but this is blank, alerting degrades to log (never crashes).
ALERT_WEBHOOK_URL=
# Percent below the trailing moving-average that counts as a reopened bucket.
SIGNAL_THRESHOLD_PCT=15.0
# Length of the trailing moving-average window, in days.
SIGNAL_WINDOW_DAYS=7

# Used by the AVF Director-layer scripts (not the backend).
GOOGLE_API_KEY=
