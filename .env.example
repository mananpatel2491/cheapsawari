# cheapsawari environment — copy to .env and fill in. .env is gitignored (never commit secrets).

# Which fare data source to use: "mock" (default, zero-quota, used by tests),
# "travelpayouts" (live, free), or "amadeus" (DEPRECATED — Self-Service shut down 2026-07-17).
FARE_PROVIDER=mock

# --- Travelpayouts / Aviasales (live provider, free) ---
# Affiliate token from the Travelpayouts dashboard (required when FARE_PROVIDER=travelpayouts).
# Returns CACHED cheapest-price-by-route data (~2–7 day storage), not live bookable fares,
# and no booking-class/bucket code. Free; no per-call charge. Daily polling is well within use.
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_CURRENCY=usd
# Optional public affiliate marker (Slice 18) used to build Aviasales "book this fare"
# deep links on the dashboard. Not a secret (appears in public URLs); links work without it.
TRAVELPAYOUTS_MARKER=

# Amadeus Self-Service credentials (DEPRECATED — portal decommissioned 2026-07-17; kept for
# reference only). Use FARE_PROVIDER=travelpayouts instead.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CURRENCY=USD

# --- Persistence ---
# Store backend: "sqlite" (default, local) or "firestore" (cloud; used in prod).
WATCH_STORE=sqlite
# SQLite file path (when WATCH_STORE=sqlite). Gitignored.
SQLITE_PATH=cheapsawari.db
# GCP project for Firestore (when WATCH_STORE=firestore). Cloud Run infers this from
# the metadata server; set locally if ADC doesn't resolve it. e.g. cheapsawari
GOOGLE_CLOUD_PROJECT=

# --- Scheduled polling (Slice 3a) ---
# Max active watches queried per poll run — keeps the fleet under the provider quota.
POLL_MAX_PER_RUN=60
# Optional shared secret. If set, POST /api/v1/poll requires header X-Poll-Token: <value>.
# Leave blank for local/dev (endpoint open); set it in cloud so the public URL is protected.
POLL_TOKEN=

# --- Signal detection + alerts (Slice 4 / 16) ---
# Where to deliver "bucket reopened" alerts: "log" (default; zero-cost, prod-safe,
# captured in Cloud Run logs), "webhook", or "email".
ALERT_CHANNEL=log
# Incoming-webhook URL for ALERT_CHANNEL=webhook (Slack/Discord/Mattermost/generic).
# If ALERT_CHANNEL=webhook but this is blank, alerting degrades to log (never crashes).
ALERT_WEBHOOK_URL=
# Percent below the trailing moving-average that counts as a reopened bucket. This is the
# server DEFAULT; a watch may override it per-tracking via alert_threshold_pct (Slice 16).
SIGNAL_THRESHOLD_PCT=15.0
# Length of the trailing moving-average window, in days.
SIGNAL_WINDOW_DAYS=7

# --- Email notifications (Slice 16) ---
# Set ALERT_CHANNEL=email to email each watch owner when their bucket reopens. Stdlib
# SMTP (no new dependency, ~$0). For a Gmail account: enable 2-Step Verification, create
# an App Password (Google Account -> Security -> App passwords), and set:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=<your gmail>
#   SMTP_PASSWORD=<the 16-char app password>  ALERT_EMAIL_FROM=<your gmail>
# If SMTP is unconfigured, ALERT_CHANNEL=email degrades to log (never crashes).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# STARTTLS on by default; set to false only for a plaintext/local relay.
SMTP_USE_TLS=true
# The From address (Gmail requires this to be the authenticated SMTP_USER).
ALERT_EMAIL_FROM=
# Optional fallback recipient when a watch has no owner_email (e.g. legacy watches).
ALERT_EMAIL_TO=
# Linked in the alert email body; the public app URL.
APP_BASE_URL=https://cheapsawari.web.app

# Used by the AVF Director-layer scripts (not the backend).
GOOGLE_API_KEY=
