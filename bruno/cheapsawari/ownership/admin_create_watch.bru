meta {
  name: Ownership · owner creates a watch (owned by owner)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/watches
  body: json
}

body:json {
  {
    "origin": "jfk",
    "destination": "lax",
    "departure_date": "2026-09-15"
  }
}

vars:post-response {
  adminWatchId: res.body.id
}

docs {
  A created watch is stamped with the signed-in user's email as owner_email.
}

assert {
  res.status: eq 201
  res.body.owner_email: eq {{adminEmail}}
}
