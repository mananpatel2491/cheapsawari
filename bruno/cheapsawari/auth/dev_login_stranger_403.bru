meta {
  name: Auth · non-allowlisted email is refused (403)
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/api/v1/auth/dev
  body: json
}

body:json {
  {
    "email": "{{strangerEmail}}"
  }
}

docs {
  Even in dev mode the allowlist is enforced: an email the owner never granted cannot
  sign in. (In prod the same check runs after Google verifies the identity.)
}

assert {
  res.status: eq 403
}
