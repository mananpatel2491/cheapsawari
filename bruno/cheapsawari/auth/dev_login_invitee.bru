meta {
  name: Auth · invited user can sign in (non-admin)
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/v1/auth/dev
  body: json
}

body:json {
  {
    "email": "{{inviteEmail}}"
  }
}

docs {
  The user the owner just allowlisted can now sign in, and is NOT an admin.
}

assert {
  res.status: eq 200
  res.body.email: eq {{inviteEmail}}
  res.body.is_admin: eq false
}
