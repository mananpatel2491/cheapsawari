meta {
  name: Admin · adding the owner is rejected (400)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/admin/users
  body: json
}

body:json {
  {
    "email": "{{adminEmail}}"
  }
}

docs {
  The owner always has access and is not an allowlist row; re-adding them is a 400.
}

assert {
  res.status: eq 400
}
