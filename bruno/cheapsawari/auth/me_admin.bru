meta {
  name: Auth · me reflects the owner session
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v1/auth/me
}

docs {
  The session cookie set by the dev login resolves to the owner. Confirms the cookie
  jar is carrying the session across requests.
}

assert {
  res.status: eq 200
  res.body.email: eq {{adminEmail}}
  res.body.is_admin: eq true
}
